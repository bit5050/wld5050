# Copy to .env.local — never commit .env.local

# ─── World ID 4 (browser) ───────────────────────────────────────────────────
# From https://developer.worldcoin.org — must match WLD5050.sol APP_ID constant exactly
NEXT_PUBLIC_WLD_APP_ID=app_your_portal_app_id
NEXT_PUBLIC_WLD_ACTION=enter-raffle

# ─── World ID 4 (server — IDKit RP signing; RP ID is NOT stored in the contract) ─
WORLD_RP_ID=rp_your_relying_party_id
WORLD_RP_SIGNING_KEY=0xyour_rp_signing_key_hex

# ─── Privy (browser + server) ─────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── WLD5050 contract (browser) — set after npm run deploy:mainnet ──────────
NEXT_PUBLIC_WLD5050_CONTRACT=0x98cB5B000F557C9A07FD724BB7a846486bD24C5C
NEXT_PUBLIC_CHAIN_ID=480
NEXT_PUBLIC_WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# ─── RPC (server only) ──────────────────────────────────────────────────────
ETH_MAINNET_RPC_URL=
WORLD_CHAIN_RPC_URL=

# ─── Optional ───────────────────────────────────────────────────────────────
CHAINLINK_CRE_API_KEY=
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/QuBtWlQ4-etGM_BYSItRQ
