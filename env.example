# Copy to .env.local — never commit .env.local

# ─── World ID 4 (browser) ───────────────────────────────────────────────────
# From https://developer.worldcoin.org — must match WLD5050.sol APP_ID constant
NEXT_PUBLIC_WLD_APP_ID=app_wld5050
NEXT_PUBLIC_WLD_ACTION=enter-raffle

# ─── World ID 4 (server — IDKit RP signing) ─────────────────────────────────
# Register an RP in the World Developer Portal; signing key stays server-only
WORLD_RP_ID=rp_your_relying_party_id
WORLD_RP_SIGNING_KEY=0xyour_rp_signing_key_hex

# ─── Privy (browser + server) ─────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── WLD5050 contract (browser) — set after npm run deploy:mainnet ──────────
NEXT_PUBLIC_WLD5050_CONTRACT=
NEXT_PUBLIC_CHAIN_ID=480
NEXT_PUBLIC_WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# ─── RPC (server only) ──────────────────────────────────────────────────────
ETH_MAINNET_RPC_URL=
WORLD_CHAIN_RPC_URL=

# ─── Optional ───────────────────────────────────────────────────────────────
CHAINLINK_CRE_API_KEY=
