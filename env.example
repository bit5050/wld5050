# Copy to .env.local — never commit .env.local

# ─── World ID 4 (browser) ───────────────────────────────────────────────────
# From https://developer.worldcoin.org — must match WLD5050.sol APP_ID constant exactly
NEXT_PUBLIC_WLD_APP_ID=app_your_portal_app_id
NEXT_PUBLIC_WLD_ACTION=enter-raffle

# ─── World ID 4 (server — IDKit RP signing; RP ID is NOT stored in the contract) ─
WORLD_RP_ID=rp_your_relying_party_id
WORLD_RP_SIGNING_KEY=0xyour_rp_signing_key_hex

# ─── Privy (browser + server) ─────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── WLD5050 contract (browser) ───────────────────────────────────────────────
# Production World Chain deploy. Also canonical in lib/contracts/contract-address.ts
# (legacy env values are ignored and resolve to this address).
NEXT_PUBLIC_WLD5050_CONTRACT=0x787C5b5B464CEa2D1482e3f0e605171B1f0D322E
NEXT_PUBLIC_CHAIN_ID=480
NEXT_PUBLIC_WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# ─── RPC (server only) ──────────────────────────────────────────────────────
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
WORLD_CHAIN_RPC_URL=

# ─── Winner ENS claim (Ethereum L1) ─────────────────────────────────────────
# Deploy: cd wld5050-contracts && npm run ens-claim:deploy
# Approve: npm run ens-claim:approve -- --registrar 0xYourRegistrar
NEXT_PUBLIC_WINNER_ENS_CLAIM_REGISTRAR=0x695da60e4145c5df881df643681c6f0cf1f1b808
# Signs claim payloads for /api/ens-claim/signature (server only; often same as operator key)
ENS_CLAIM_SIGNER_PRIVATE_KEY=

# ─── Optional ───────────────────────────────────────────────────────────────
CHAINLINK_CRE_API_KEY=
