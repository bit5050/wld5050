# Copy to wld5050-contracts/.env — never commit .env

PRIVATE_KEY=

# World Chain Mainnet (chainId 480)
WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# Ethereum mainnet — CRE workflow registry deploy, ENS, winner subnames
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Confirmed World Chain Mainnet addresses
WORLD_ID_ROUTER=0x17B354dD2595411ff79041f930e491A4Df39A278
USDC_ADDRESS=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1
WLD_ADDRESS=0x2cFc85d8E48F8EAB294be644d9E25C3030863003
CRE_FORWARDER=0x6E9EE680ef59ef64Aa8C7371279c27E496b5eDc1
PLATFORM_WALLET=0x655F553fF96791C225C97a07691C1CC198A223c4

# Production WLD5050 on World Chain (matches root NEXT_PUBLIC_WLD5050_CONTRACT)
WLD5050_CONTRACT=0x787C5b5B464CEa2D1482e3f0e605171B1f0D322E

# Hackathon mock-forwarder deploy uses CRE_FORWARDER above.
# Production CRE forwarder (post Early Access): 0x98B8335d29Aca40840Ed8426dA1A0aAa8677d8D1

# Etherscan API key (free at https://etherscan.io/myapikey) — used for Worldscan source verify
ETHERSCAN_API_KEY=

# CRE CLI — Ethereum wallet for workflow registry deploy/activate (needs ETH on mainnet)
# Often the same key as PRIVATE_KEY if that wallet is funded on Ethereum L1
CRE_ETH_PRIVATE_KEY=

# Winner ENS claim registrar (Ethereum L1 — separate from WLD5050 on World Chain)
OPERATOR_PRIVATE_KEY=
ENS_CLAIM_SIGNER_PRIVATE_KEY=
WINNER_ENS_CLAIM_REGISTRAR=0xef9ad4bd204eace9d2b2a0f53326c7e83e8c49f9
