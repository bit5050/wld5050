# =============================================================================
# WLD5050 — environment template
# Copy to .env.local and fill in real values. Commit .env.example only.
# =============================================================================

# -----------------------------------------------------------------------------
# Public (browser-safe — NEXT_PUBLIC_ is bundled into client JavaScript)
# These IDs are designed to be public; do NOT put secrets here.
# -----------------------------------------------------------------------------

# World ID — https://developer.worldcoin.org
NEXT_PUBLIC_WLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WLD_ACTION=enter-raffle

# Privy — App ID is public; App Secret belongs in server section below
NEXT_PUBLIC_PRIVY_APP_ID=clxxxxxxxxxxxxxxxxxxxxxxxx

# World Chain contract + chain id (public on-chain data)
NEXT_PUBLIC_WLD5050_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=480

# -----------------------------------------------------------------------------
# Server-only (no NEXT_PUBLIC_ prefix — never import these in client components)
# Used in API routes, server actions, and automation only.
# -----------------------------------------------------------------------------

# Ethereum mainnet RPC for ENS resolution (/api/ens)
# Use a dedicated key with domain restrictions; never expose in the browser.
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# World Chain RPC for server-side reads / tx preparation
WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Privy server secret — webhooks, server-side auth (https://dashboard.privy.io)
PRIVY_APP_SECRET=

# Chainlink CRE — automation / settlement (server or CI only)
CHAINLINK_CRE_API_KEY=

# Agent / treasury private key — NEVER use NEXT_PUBLIC_; keep out of frontend entirely
# AGENT_PRIVATE_KEY=
